#. Description of the plugin
#: sk-live-search.php
msgid "A plugin to add live search functionality to your WordPress site."
msgstr "افزودن امکان جستجو زنده به وردپرس."

#. Author of the plugin
#: sk-live-search.php
msgid "Mohammad Anbarestany"
msgstr "محمد عنبرستانی"

#: sk-live-search.php:150 sk-live-search.php:201
msgid "no results found..."
msgstr "نتیجه‌ای یافت نشد..."

#: sk-live-search.php:194
msgid "More results..."
msgstr "نتایج بیشتر..."

#: sk-live-search.php:133
msgid "Missing nonce"
msgstr "توکن امنیتی موجود نیست"

#: sk-live-search.php:140
msgid "Invalid nonce"
msgstr "توکن امنیتی نامعتبر"

#: sk-live-search.php:30
msgid "Search suggestions"
msgstr "پیشنهادات جستجو"

#: sk-live-search.php:31
msgid "1 suggestion available"
msgstr "۱ پیشنهاد موجود است"

#. translators: %d is the number of suggestions available.
#: sk-live-search.php:33
#, php-format
msgid "%d suggestions available"
msgstr "%d پیشنهاد موجود است"

#: sk-live-search.php:34
msgid "Search temporarily unavailable. Please try again."
msgstr "جستجو موقتاً در دسترس نیست. لطفاً دوباره تلاش کنید."

#: sk-live-search.php:35
msgid "Search security token refresh failed"
msgstr "بروزرسانی توکن امنیتی جستجو ناموفق"

#: sk-live-search.php:36
msgid "Search request failed"
msgstr "درخواست جستجو ناموفق"

#. Plugin Name of the plugin
#: sk-live-search.php
msgid "SK Live Search"
msgstr "جستجوی زنده SK"

#. Author URI of the plugin
#: sk-live-search.php
msgid "https://anbarestany.ir"
msgstr "https://anbarestany.ir"

#. translators: 1: result index number, 2: post title.
#: sk-live-search.php:175
#, php-format
msgid "Search result %1$d: %2$s"
msgstr "نتایج جستجو %1$d: %2$s"

#. translators: %s is the search query.
#: sk-live-search.php:191
#, php-format
msgid "View more search results for: %s"
msgstr "دیدن نتایج بیشتر برای: %s"
